{
    "$schema": "https://raw.githubusercontent.com/ErikReider/SwayNotificationCenter/refs/heads/main/src/configSchema.json",
    "positionX": "right",
    "positionY": "top",
    "control-center-positionX": "none",
    "control-center-positionY": "none",
    "control-center-margin-top": 2,
    "control-center-margin-bottom": 2,
    "control-center-margin-right": 1,
    "control-center-margin-left": 0,
    "control-center-width": 400,
    "control-center-height": 300,
    "fit-to-screen": true,
    "layer-shell": true,
    "cssPriority": "user",
    "notification-icon-opacity": 1.0,
    "timeout": 10,
    "timeout-low": 5,
    "timeout-critical": 0,
    "notification-window-width": 400,
    "keyboard-shortcuts": true,
    "image-visibility": "when-available",
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": true,
    "script-fail-notify": true,
    "widgets": [
        "title",
        "dnd",
        "notifications",
        "mpris",
        "volume",
        "backlight",
        "buttons-grid"
    ],
    "widget-config": {
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": "Clear All"
        },
        "dnd": {
            "text": "Do Not Disturb"
        },
        "volume": {
            "label": " 󰕾 "
        },
        "backlight": {
            "label": " 󰃟 ",
            "device": "intel_backlight"
        },
        "buttons-grid": {
            "actions": [
                {
                    "label": "  _wifi  ",
                    "command": "nm-connection-editor",
                    "type": "normal"
                },
                {
                    "label": "  󰂯  ",
                    "command": "blueman-manager",
                    "type": "normal"
                },
                {
                    "label": "  󰃛  ",
                    "command": "pkill -x wlsunset || wlsunset -l 40 -L 116",
                    "type": "toggle"
                },
                {
                    "label": "  ⏻  ",
                    "command": "wlogout",
                    "type": "normal"
                }
            ]
        }
    }
}