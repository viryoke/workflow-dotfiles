progress_error = { fg = "#d20f39", bg = "#ccd0da" }

permissions_t = { fg = "#40a02b" }
permissions_r = { fg = "#8839ef" }
permissions_w = { fg = "#d20f39" }
permissions_x = { fg = "#fe640b" }
