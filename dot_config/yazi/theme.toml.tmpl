# Yazi theme - workflow-dotfiles managed by chezmoi
{{- if eq .theme "mocha" }}
# Catppuccin Mocha
[manager]
cwd = { fg = "#89b4fa", bold = true }
hovered = { fg = "#1e1e2e", bg = "#cba6f7" }
preview_hovered = { bg = "#313244" }

tab_active = { fg = "#cba6f7", bg = "#1e1e2e" }
tab_inactive = { fg = "#6c7086", bg = "#181825" }
tab_width = 1

count_selected = { fg = "#a6e3a1", bold = true }
count_copied = { fg = "#a6e3a1", bold = true }
count_cut = { fg = "#f38ba8", bold = true }

border_symbol = "│"
border_style = { fg = "#45475a" }

[mode]
normal_main = { fg = "#1e1e2e", bg = "#cba6f7", bold = true }
normal_alt = { fg = "#cba6f7", bg = "#313244" }

select_main = { fg = "#1e1e2e", bg = "#a6e3a1", bold = true }
select_alt = { fg = "#a6e3a1", bg = "#313244" }

unset_main = { fg = "#1e1e2e", bg = "#f38ba8", bold = true }
unset_alt = { fg = "#f38ba8", bg = "#313244" }

[status]
separator_open = ""
separator_close = ""
separator_style = { fg = "#45475a", bg = "#45475a" }

progress_label = { fg = "#cba6f7", bold = true }
progress_normal = { fg = "#cba6f7", bg = "#313244" }
progress_error = { fg = "#f38ba8", bg = "#313244" }

permissions_t = { fg = "#a6e3a1" }
permissions_r = { fg = "#cba6f7" }
permissions_w = { fg = "#f38ba8" }
permissions_x = { fg = "#fab387" }
permissions_s = { fg = "#585b70" }
permissions_- = { fg = "#585b70" }

[input]
border = { fg = "#cba6f7" }
title = { fg = "#cba6f7" }
value = { fg = "#cdd6f4" }
selected = { bg = "#313244" }

[which]
cols = 3
rows = 3
mask = { bg = "#313244" }
cand = { fg = "#cba6f7" }
rest = { fg = "#6c7086" }
desc = { fg = "#a6adc8" }
separator_style = { fg = "#585b70" }

[help]
on = { fg = "#cba6f7" }
run = { fg = "#a6e3a1" }
desc = { fg = "#6c7086" }
hovered = { bg = "#313244", bold = true }
footer = { fg = "#1e1e2e", bg = "#cba6f7" }

[notify]
title_info = { fg = "#a6e3a1" }
title_warn = { fg = "#fab387" }
title_error = { fg = "#f38ba8" }

[filetype]
rules = [
  { mime = "image/*", fg = "#89b4fa" },
  { mime = "video/*", fg = "#fab387" },
  { mime = "audio/*", fg = "#f38ba8" },
  { mime = "application/pdf", fg = "#f5c2e7" },
  { mime = "application/zip", fg = "#f5c2e7" },
  { name = "*", fg = "#cdd6f4" },
  { name = "*/", fg = "#89b4fa", bold = true },
]
{{- else }}
# Catppuccin Latte
[manager]
cwd = { fg = "#1e66f5", bold = true }
hovered = { fg = "#eff1f5", bg = "#8839ef" }
preview_hovered = { bg = "#ccd0da" }

